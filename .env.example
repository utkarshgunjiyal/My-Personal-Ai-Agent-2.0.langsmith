# LLM provider — set LLM_PROVIDER to "openai" or "openrouter"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# Database
MONGO_URL=
DB_NAME=ai_decision_engine

# Authentication
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — the deployed frontend origin
FRONTEND_URL=http://localhost:3000

# LangSmith (optional tracing)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=personal-ai-agent

# Admin user seeded on startup (change the password before deploying)
ADMIN_EMAIL=
ADMIN_PASSWORD=
